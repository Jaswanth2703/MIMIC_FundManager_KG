# Copy this file to .env and fill in your credentials
# These are read by config.py via os.environ.get()

# Kite Connect (Zerodha) — required for step03 (OHLCV fetch)
# Access token expires daily; regenerate from https://kite.trade/connect/login
KITE_API_KEY=your_kite_api_key
KITE_ACCESS_TOKEN=your_daily_access_token

# Google Gemini API — optional (used for NLP augmentation)
GEMINI_API_KEY=your_gemini_key

# Neo4j — required for steps 10, 11, 13, 15
# Install Neo4j Desktop or use Docker: docker run -p 7687:7687 neo4j
NEO4J_URI=neo4j://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password
